---
const features = [
  {
    title: 'High-Performance Protocols',
    body: 'Zero-copy binary protocol for maximum throughput, plus Redis-compatible RESP2 for seamless integration with existing Redis tools and clients.',
  },
  {
    title: 'Scalable Architecture',
    body: 'Shared-nothing architecture with per-shard RWMutex for near-linear scaling across CPU cores and low-contention operations.',
  },
  {
    title: 'Efficient TTL Management',
    body: 'O(1) TTL eviction via timing wheel with lazy eviction on read, ensuring expired keys are removed efficiently without impacting performance.',
  },
  {
    title: 'Cloud-Native Design',
    body: 'Built for modern cloud environments with configurable memory limits, metrics collection, and observability through Prometheus and OpenTelemetry.',
  },
];
---
<section class="section" id="features">
  <div class="wrap">
    <div class="section__head">
      <h2>Designed for Modern Applications</h2>
      <p>
        Tellstone is built to accelerate cloud-native applications by providing
        high-performance in-memory storage with flexible deployment options.
      </p>
    </div>

    <div class="features__grid">
      {features.map((f) => (
        <div class="feature">
          <div class="feature__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <path d="M4 12 L10 12 L12 6 L15 18 L17 12 L20 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

---
import '../styles/statbar.css';

const stats = [
  { value: 'Shared Nothing', label: 'thread-per-core for near-linear scaling. Higher throughput on a smaller infra footprint.' },
  { value: 'Zero-Copy', label: 'binary protocol avoids text parsing and Protobuf overhead' },
  { value: 'Redis-Compatible', label: 'DropIn replacement for Redis which makes the migration less complex and increases performance directly.' },
];
---
<section class="stats">
  <div class="wrap stats__row">
    {stats.map((s) => (
      <div class="stat">
        <div class="stat__value">{s.value}</div>
        <div class="stat__label">{s.label}</div>
      </div>
    ))}
  </div>
</section>

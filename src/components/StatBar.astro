---
const stats = [
  { value: 'Zero-Copy', label: 'binary protocol avoids text parsing and Protobuf overhead' },
  { value: 'Redis-Compatible', label: 'RESP2 listener works with redis-cli, memtier, and existing clients' },
  { value: '4.7x Redis', label: 'throughput vs Redis 8.8 in pinned benchmarks (same hardware)' },
  { value: 'Shared Nothing', label: 'GOMAXPROCS shards with per-shard RWMutex for near-linear scaling' },
];
---
<section class="stats">
  <div class="wrap stats__row">
    {stats.map((s) => (
      <div class="stat">
        <div class="stat__value">{s.value}</div>
        <div class="stat__label">{s.label}</div>
      </div>
    ))}
  </div>
</section>

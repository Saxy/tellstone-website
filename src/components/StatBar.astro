---
// Key architectural facts about Tellstone
const stats = [
  { value: 'Shared-Nothing', label: 'architecture that eliminates scaling bottlenecks by utilizing every core on every machine' },
  { value: '2', label: 'protocols: zero-copy binary + Redis-compatible RESP2' },
  { value: 'O(1)', label: 'TTL eviction via timing wheel for efficient key management' },
  { value: 'Go', label: 'written entirely in Go for performance and portability' },
  { value: 'Apache-2.0', label: 'open source license for freedom and flexibility' },
];
---
<section class="stats">
  <div class="wrap stats__row">
    {stats.map((s) => (
      <div class="stat">
        <div class="stat__value">{s.value}</div>
        <div class="stat__label">{s.label}</div>
      </div>
    ))}
  </div>
</section>

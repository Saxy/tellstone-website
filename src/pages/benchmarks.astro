---
import Landing from '../layouts/Landing.astro';
import Benchmarks from '../components/Benchmarks.astro';
---
<Landing
  title="Benchmarks — Tellstone"
  description="See how Tellstone compares to Redis, Valkey, and Dragonfly in throughput and latency across 4, 16, and 32 CPU cores."
>
  <header class="nav">
    <div class="wrap nav__row">
      <a class="nav__brand" href="/">
        <img src="/logo.svg" alt="Tellstone logo" />
        Tellstone
      </a>
      <nav class="nav__links">
        <a href="/docs/getting-started/introduction/">Docs</a>
        <a href="/#features">Features</a>
        <a href="/benchmarks" class="nav__link--active">Benchmarks</a>
        <a href="/roadmap">Roadmap</a>
        <a href="https://github.com/Saxy/Tellstone">GitHub</a>
      </nav>
    </div>
  </header>

  <main>
    <Benchmarks />
  </main>

  <footer class="footer">
    <div class="wrap footer__row">
      <span>&copy; {new Date().getFullYear()} The Tellstone Project. Apache-2.0 License.</span>
      <div class="footer__links">
        <a href="/docs/getting-started/introduction/">Documentation</a>
      </div>

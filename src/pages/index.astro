---
import Landing from '../layouts/Landing.astro';
import Hero from '../components/Hero.astro';
import SharedNothingAnimation from '../components/SharedNothingAnimation.astro';
import StatBar from '../components/StatBar.astro';
import Features from '../components/Features.astro';
import CodeTabs from '../components/CodeTabs.astro';
import CTASection from '../components/CTASection.astro';

const commandTabs = [
  {
    label: 'RESP (redis-cli)',
    code:
      '<span class="tok-com"># task run:resp</span>\n' +
      '<span class="tok-cmd">redis-cli</span> -p 6379 PING\n' +
      '<span class="tok-com">-> PONG</span>\n' +
      '<span class="tok-cmd">redis-cli</span> -p 6379 SET k v <span class="tok-key">EX</span> 60\n' +
      '<span class="tok-com">-> OK</span>\n' +
      '<span class="tok-cmd">redis-cli</span> -p 6379 GET k\n' +
      '<span class="tok-com">-> "v"</span>',
  },
  {
    label: 'Native Go client',
    code:
      '<span class="tok-cmd">import</span> <span class="tok-str">"github.com/Saxy/Tellstone/internal/network"</span>\n\n' +
      'c, _ := network.Dial(<span class="tok-str">"127.0.0.1:9988"</span>, 2*time.Second)\n' +
      'defer c.Close()\n\n' +
      'scratch := make([]byte, 4096)\n' +
      'c.Set([]byte(<span class="tok-str">"hello"</span>), []byte(<span class="tok-str">"world"</span>), 0, scratch)\n' +
      'val, _ := c.Get([]byte(<span class="tok-str">"hello"</span>), scratch)',
  },
];

const installTabs = [
  {
    label: 'Build',
    code:
      '<span class="tok-cmd">git</span> clone https://github.com/Saxy/Tellstone\n' +
      '<span class="tok-cmd">cd</span> Tellstone\n' +
      '<span class="tok-cmd">task</span> build   <span class="tok-com"># -> ./bin/tellstone</span>',
  },
  {
    label: 'Run (binary only)',
    code: '<span class="tok-cmd">task</span> run   <span class="tok-com"># 127.0.0.1:9988</span>',
  },
  {
    label: 'Run (+ RESP)',
    code: '<span class="tok-cmd">task</span> run:resp   <span class="tok-com"># :9988 and :6379</span>',
  },
];
---
<Landing
  title="Tellstone — High-Performance In-Memory Database"
  description="Tellstone is an open-source, cloud-native in-memory database written in Go — a RESP2-compatible alternative to Redis with zero-copy binary protocol, shared-nothing architecture, optional ChaCha20-Poly1305 encryption, and a zero-GC hot path."
>
  <header class="nav">
    <div class="wrap nav__row">
      <a class="nav__brand" href="/">
        <img src="/logo.svg" alt="Tellstone logo" />
        Tellstone
      </a>
      <nav class="nav__links">
        <a href="/docs/getting-started/introduction/">Docs</a>
        <a href="/#features">Features</a>
        <a href="https://github.com/Saxy/Tellstone">GitHub</a>
      </nav>
    </div>
  </header>

  <main>
    <Hero />
    <StatBar />
    <section class="section">
      <div class="wrap">
        <div class="section__head">
          <h2>One Goroutine Per Shard, Not One-Size-Fits-All</h2>
          <p>Every shard runs its own goroutine with an independent lock-free map — no contention, no cross-shard coordination, just parallel execution.</p>
        </div>
        <SharedNothingAnimation />
      </div>
    </section>
    <Features />

    <section class="section">
      <div class="wrap">
        <div class="section__head">
          <h2>Flexible Protocol Support</h2>
          <p>Choose the protocol that best fits your needs: ultra-fast zero-copy binary protocol for maximum performance, or Redis-compatible RESP2 for seamless integration with existing tools.</p>
        </div>
        <CodeTabs id="commands" tabs={commandTabs} />
      </div>
    </section>

    <section class="section">
      <div class="wrap">
        <div class="section__head">
          <h2>Easy Setup & Deployment</h2>
          <p>Build Tellstone from source with Go and Task, or run it directly with configurable flags and environment variables.</p>
        </div>
        <CodeTabs id="install" tabs={installTabs} />
      </div>
    </section>

    <CTASection />
  </main>

  <footer class="footer">
    <div class="wrap footer__row">
      <span>&copy; {new Date().getFullYear()} The Tellstone Project. Apache-2.0 License.</span>
      <div class="footer__links">
        <a href="/docs/getting-started/introduction/">Documentation</a>
        <a href="https://github.com/Saxy/Tellstone" class="btn btn--ghost">
          <img src="/github-icon.svg" alt="GitHub" width="18" height="18" />
          GitHub
        </a>
        <a href="https://github.com/Saxy/tellstone-website" target="_blank" class="btn btn--ghost">
          <img src="/github-icon.svg" alt="GitHub" width="18" height="18" />
          Website Source
        </a>
        <a href="https://discord.gg/kEf78DUFX" target="_blank" class="btn btn--ghost">
          <img src="/discord-icon.svg" alt="Discord" width="18" height="18" />
          Join Discord
        </a>
      </div>
    </div>
  </footer>
</Landing>
